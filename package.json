{
  "name": "upscale-team",
  "displayName": "Upscale",
  "publisher": "upscale-team",
  "icon": "images/logo.png",
  "description": "Highlight a line of code. Get an instant suggestion to improve it.",
  "version": "0.0.7",
  "repository": {
    "type": "git",
    "url": "https://github.com/nadashawerr/code-upscale-extension"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Upscale",
      "properties": {
        "upscale-team.geminiApiKey": {
          "type": "string",
          "description": "Your Gemini API key from https://aistudio.google.com/api-keys"
        }
      }
    },
    "commands": [
      {
        "command": "upscale-team.upscale",
        "title": "Upscale"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "upscale-team.upscale",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.15",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1"
  }
}
